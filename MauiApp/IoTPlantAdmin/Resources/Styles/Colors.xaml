<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
        Color palette inspired by the React + MUI frontend theme.
        Primary: #E30613 (DHBW Lörrach brand red)
        See frontend/src/App.tsx for the MUI createTheme() configuration.
    -->

    <!-- Primary / Accent -->
    <Color x:Key="Primary">#E30613</Color>
    <Color x:Key="PrimaryDark">#B00410</Color>
    <Color x:Key="PrimaryLight">#FF4C4C</Color>

    <!-- Background -->
    <Color x:Key="Background">#F5F5F5</Color>
    <Color x:Key="Surface">#FFFFFF</Color>

    <!-- Neutral grays (MUI default palette) -->
    <Color x:Key="Gray100">#F5F5F5</Color>
    <Color x:Key="Gray200">#E0E0E0</Color>
    <Color x:Key="Gray300">#BDBDBD</Color>
    <Color x:Key="Gray400">#9E9E9E</Color>
    <Color x:Key="Gray500">#757575</Color>
    <Color x:Key="Gray600">#616161</Color>
    <Color x:Key="Gray900">#212121</Color>

    <!-- Semantic colors -->
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Error">#F44336</Color>
    <Color x:Key="Warning">#FF9800</Color>
    <Color x:Key="Info">#2196F3</Color>

    <!-- Component-specific -->
    <Color x:Key="StorageCarton">#D9A05C</Color>

</ResourceDictionary>
