<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IoTPlantAdmin.Views.WebAppPage"
             Title="IoT Plant Web">

    <Grid RowDefinitions="Auto,*">
        <Border x:Name="TopBar" Padding="12" StrokeThickness="0" BackgroundColor="{StaticResource Primary}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
            <Label Text="Quelle:" FontAttributes="Bold" TextColor="White" VerticalTextAlignment="Center" />

                <Picker x:Name="SourcePicker"
                        Grid.Column="1"
                BackgroundColor="White"
                TextColor="{StaticResource Gray900}"
                TitleColor="{StaticResource Gray900}"
                        SelectedIndexChanged="OnSourcePickerChanged">
                    <Picker.Items>
                        <x:String>Lokal (http://localhost:4173)</x:String>
                        <x:String>Server (https://localhost)</x:String>
                    </Picker.Items>
                </Picker>

            <Button Grid.Column="2"
                Text="Neu laden"
                BackgroundColor="White"
                TextColor="{StaticResource Primary}"
                Clicked="OnReloadClicked" />
            <Button Grid.Column="3"
                Text="Vollbild"
                BackgroundColor="White"
                TextColor="{StaticResource Primary}"
                Clicked="OnToggleImmersiveClicked" />

              <Label Grid.Row="1"
                  Text="URL:"
                  FontAttributes="Bold"
                  TextColor="White"
                  VerticalTextAlignment="Center" />
              <Entry x:Name="CustomUrlEntry"
                  Grid.Row="1"
                  Grid.Column="1"
                  Grid.ColumnSpan="2"
                  Placeholder="z. B. 192.168.178.10:4173"
                  BackgroundColor="White"
                  TextColor="{StaticResource Gray900}"
                  PlaceholderColor="{StaticResource Gray500}"
                  ReturnType="Go"
                  Completed="OnCustomUrlCompleted" />
              <Button Grid.Row="1"
                   Grid.Column="3"
                   Text="Oeffnen"
                   BackgroundColor="White"
                   TextColor="{StaticResource Primary}"
                   Clicked="OnOpenCustomClicked" />

              <Label Grid.Row="2"
                       Text="●"
                       x:Name="StatusDot"
                       FontSize="16"
                       VerticalTextAlignment="Center" />
              <Label Grid.Row="2"
                       Grid.Column="1"
                       Grid.ColumnSpan="3"
                       x:Name="StatusLabel"
                      TextColor="White"
                       LineBreakMode="TailTruncation"
                       VerticalTextAlignment="Center" />

              <Label Grid.Row="3"
                       Grid.ColumnSpan="4"
                       x:Name="UrlLabel"
                       FontSize="12"
                      TextColor="White"
                      Opacity="0.95"
                       LineBreakMode="TailTruncation"
                       VerticalTextAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <WebView x:Name="AppWebView"
                     Navigating="OnWebViewNavigating"
                     Navigated="OnWebViewNavigated" />

            <Button x:Name="ShowToolbarButton"
                    Text="Leiste"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    Clicked="OnShowToolbarClicked"
                    IsVisible="False"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="0,12,12,0" />
        </Grid>
    </Grid>

</ContentPage>
