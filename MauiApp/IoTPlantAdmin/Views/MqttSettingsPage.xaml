<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IoTPlantAdmin.ViewModels"
             x:Class="IoTPlantAdmin.Views.MqttSettingsPage"
             x:DataType="vm:MqttSettingsViewModel"
             Title="MQTT Settings"
             BackgroundColor="{StaticResource Background}">

    <ScrollView Padding="16">
        <StackLayout Spacing="16">

            <!-- ── Connection Status ────────────────────── -->
            <Frame Padding="16"
                   CornerRadius="12"
                   BackgroundColor="White"
                   BorderColor="{StaticResource Gray200}">
                <StackLayout Spacing="8">
                    <Label Text="Connection Status"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}" />
                    <HorizontalStackLayout Spacing="8">
                        <BoxView WidthRequest="12"
                                 HeightRequest="12"
                                 CornerRadius="6"
                                 Color="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}" />
                        <Label Text="{Binding ConnectionStatus}"
                               FontSize="15"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding LastError}"
                           FontSize="13"
                           TextColor="{StaticResource Gray500}"
                           IsVisible="{Binding LastError, Converter={StaticResource IsNotNullConverter}}" />
                </StackLayout>
            </Frame>

            <!-- ── Broker Configuration ─────────────────── -->
            <Frame Padding="16"
                   CornerRadius="12"
                   BackgroundColor="White"
                   BorderColor="{StaticResource Gray200}">
                <StackLayout Spacing="12">
                    <Label Text="Broker Configuration"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}" />

                    <!-- Protocol -->
                    <StackLayout Spacing="4">
                        <Label Text="Protocol"
                               FontSize="13"
                               TextColor="{StaticResource Gray600}" />
                        <Picker SelectedItem="{Binding Protocol}">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>ws</x:String>
                                    <x:String>wss</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>
                    </StackLayout>

                    <!-- Host -->
                    <StackLayout Spacing="4">
                        <Label Text="Host"
                               FontSize="13"
                               TextColor="{StaticResource Gray600}" />
                        <Entry Text="{Binding Host}"
                               Placeholder="e.g. raspberrypi.local"
                               Keyboard="Url" />
                    </StackLayout>

                    <!-- Port -->
                    <StackLayout Spacing="4">
                        <Label Text="Port"
                               FontSize="13"
                               TextColor="{StaticResource Gray600}" />
                        <Entry Text="{Binding Port}"
                               Placeholder="1883"
                               Keyboard="Numeric" />
                    </StackLayout>

                    <!-- Client ID -->
                    <StackLayout Spacing="4">
                        <Label Text="Client ID"
                               FontSize="13"
                               TextColor="{StaticResource Gray600}" />
                        <Entry Text="{Binding ClientId}"
                               Placeholder="plant-admin-..." />
                    </StackLayout>
                </StackLayout>
            </Frame>

            <!-- ── Authentication ───────────────────────── -->
            <Frame Padding="16"
                   CornerRadius="12"
                   BackgroundColor="White"
                   BorderColor="{StaticResource Gray200}">
                <StackLayout Spacing="12">
                    <Label Text="Authentication"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}" />

                    <StackLayout Spacing="4">
                        <Label Text="Username"
                               FontSize="13"
                               TextColor="{StaticResource Gray600}" />
                        <Entry Text="{Binding Username}"
                               Placeholder="(optional)" />
                    </StackLayout>

                    <StackLayout Spacing="4">
                        <Label Text="Password"
                               FontSize="13"
                               TextColor="{StaticResource Gray600}" />
                        <Entry Text="{Binding Password}"
                               Placeholder="(optional)"
                               IsPassword="True" />
                    </StackLayout>

                    <HorizontalStackLayout Spacing="8">
                        <Switch IsToggled="{Binding UseTls}" />
                        <Label Text="Use TLS"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </StackLayout>
            </Frame>

            <!-- ── Action Buttons ───────────────────────── -->
            <StackLayout Spacing="10">
                <Button Text="Connect"
                        Command="{Binding ConnectCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="48"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />

                <Button Text="Disconnect"
                        Command="{Binding DisconnectCommand}"
                        BackgroundColor="{StaticResource Gray500}"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="48"
                        IsEnabled="{Binding IsConnected}" />

                <Button Text="Test Connection"
                        Command="{Binding TestConnectionCommand}"
                        BackgroundColor="White"
                        TextColor="{StaticResource Primary}"
                        BorderColor="{StaticResource Primary}"
                        BorderWidth="1"
                        CornerRadius="8"
                        HeightRequest="48"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
            </StackLayout>

            <!-- ── Activity indicator ───────────────────── -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center" />

        </StackLayout>
    </ScrollView>

</ContentPage>
