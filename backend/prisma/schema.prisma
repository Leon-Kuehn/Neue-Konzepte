generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Placeholder model for future sensor data storage
model SensorData {
  id          Int      @id @default(autoincrement())
  componentId String   @map("component_id")
  topic       String
  payload     Json
  receivedAt  DateTime @default(now()) @map("received_at")

  @@index([componentId])
  @@index([receivedAt])
  @@map("sensor_data")
}
