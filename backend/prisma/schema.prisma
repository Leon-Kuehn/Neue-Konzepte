// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Stores MQTT messages received from IoT plant components.
model SensorData {
  id          Int      @id @default(autoincrement())
  componentId String   @map("component_id")
  topic       String
  payload     Json
  receivedAt  DateTime @default(now()) @map("received_at")

  @@index([componentId])
  @@index([receivedAt])
  @@map("sensor_data")
}

/// Stores user-defined simulation configurations for the frontend designer.
model SimulationDefinition {
  id          String   @id
  name        String
  description String?
  repeat      Int?
  steps       Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("simulation_definitions")
}
